{
  "config": {
    "name": "virtual_users_v3_experiment",
    "description": "Virtual user research with cross-question attitude consistency focus",
    "output_dir": "results",
    "log_dir": "logs",
    "n_repeats": 5,
    "model": {
      "name": "glm-5",
      "provider": "openai",
      "temperature": 0.7,
      "max_tokens": 2048,
      "api_key_env": "OPENAI_API_KEY"
    },
    "data": {
      "name": "anes_2020",
      "data_dir": "data/raw",
      "cache_dir": "data/cache",
      "sample_size": 8,
      "seed": 42
    },
    "persona": {
      "pool_size": 300,
      "diversity_weight": 0.5,
      "ensure_demographic_match": true,
      "demographic_fields": [
        "age_group",
        "gender",
        "race",
        "education",
        "income",
        "region"
      ]
    },
    "retrieval": {
      "enabled": true,
      "top_k": 5,
      "rerank": true,
      "embedding_model": "text-embedding-ada-002"
    },
    "baselines": [
      "random",
      "mode",
      "llm_direct",
      "llm_prompt",
      "llm_s3_pas",
      "consist_agent"
    ],
    "evaluation": {
      "metrics": [
        "kl_divergence",
        "js_distance",
        "distribution_similarity",
        "mode_match_accuracy",
        "top3_accuracy",
        "cohens_kappa",
        "jaccard_similarity",
        "exact_match_accuracy"
      ],
      "n_bootstrap": 1000,
      "significance_level": 0.05,
      "save_detailed_results": true
    },
    "consistency": {
      "enabled": false,
      "acs_threshold": 0.7,
      "constraint_strength": 0.8,
      "memory_window": 10
    },
    "logging": {
      "level": "INFO",
      "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
      "file": true,
      "console": true
    }
  },
